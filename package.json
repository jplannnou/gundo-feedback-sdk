{
  "name": "@jplannnou/feedback-sdk",
  "version": "1.2.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "copy-assets": "node -e \"const fs=require('fs'),p=require('path');(function cp(s,d){fs.readdirSync(s,{withFileTypes:true}).forEach(e=>{if(e.isDirectory())cp(p.join(s,e.name),p.join(d,e.name));else if(e.name.endsWith('.css')){fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p.join(s,e.name),p.join(d,e.name))}})})('src','dist')\"",
    "verify": "node -e \"const fs=require('fs');const missing=[];['dist/index.js','dist/index.d.ts'].forEach(f=>{if(!fs.existsSync(f))missing.push(f)});fs.readdirSync('src/components').filter(f=>f.endsWith('.css')).forEach(f=>{const d='dist/components/'+f;if(!fs.existsSync(d))missing.push(d)});if(missing.length){console.error('ERROR: missing dist files:',missing.join(', '));process.exit(1)}console.log('dist verified')\"",
    "fix-imports": "node scripts/fix-esm-imports.js",
    "build": "tsc && pnpm fix-imports && pnpm copy-assets && pnpm verify",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jplannnou/gundo-feedback-sdk.git"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "@gundo/ui": "*",
    "html2canvas": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "html2canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gundo/ui": "file:../gundo-ui",
    "@types/react": "^19.0.0",
    "typescript": "^5.9.0"
  },
  "packageManager": "pnpm@10.30.1"
}
